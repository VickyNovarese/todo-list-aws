pipeline {
    agent none

    environment {
        AWS_DEFAULT_REGION = 'us-east-1'
        APP_NAME = 'todo-list-aws'
    }

    stages {
        
        stage('Static Analysis') {
            agent { label 'python-agent' } 
            steps {
                
                sh 'echo "--- Identidad en Get Code ---"; whoami; hostname'
                checkout scm
            }
        }

        stage('Static Test') {
            agent { label 'static-analysis' } 
            steps {
                sh 'echo "--- Identidad en Static Test ---"; whoami; hostname'
                checkout scm
                sh '''
                    set -e
                    python3 -m venv .venv || true
                    . .venv/bin/activate
                    pip install flake8 "bandit[sarif]"
                    python -m flake8 --format=pylint src > flake8.out || true
                    python -m bandit --exit-zero -r src -f sarif -o bandit.sarif
                '''
            }
        }

        
        stage('Deploy Staging') {
            agent any 
            steps {
                sh 'echo "--- Identidad en Deploy ---"; whoami; hostname'
                checkout scm
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY'),
                    string(credentialsId: 'AWS_SESSION_TOKEN', variable: 'AWS_SESSION_TOKEN')
                ]) {
                    sh '''
                        set -e
                        python3 -m venv .venv || true
                        . .venv/bin/activate
                        pip install aws-sam-cli awscli
                        sam build
                        sam deploy --config-env staging --no-confirm-changeset --no-fail-on-empty-changeset
                    '''
                }
            }
        }

        stage('Rest Test') {
            agent { label 'api-tests' } 
            steps {
                sh 'echo "--- Identidad en Rest Test ---"; whoami; hostname'
                checkout scm
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY'),
                    string(credentialsId: 'AWS_SESSION_TOKEN', variable: 'AWS_SESSION_TOKEN')
                ]) {
                    sh '''
                        set -e
                        python3 -m venv .venv || true
                        . .venv/bin/activate
                        pip install pytest requests awscli

                        BASE_URL=$(aws cloudformation describe-stacks \
                            --stack-name ${STACK_NAME} \
                            --query "Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue" \
                            --output text)

                        echo "BASE_URL detectada: $BASE_URL"
                        
                        # SOLUCIÓN: Extraer la URL y guardarla en un archivo
                        aws cloudformation describe-stacks \
                            --stack-name ${APP_NAME}-staging \
                            --query 'Stacks[0].Outputs[?OutputKey==`ServiceEndpoint`].OutputValue' \
                            --output text > api_url.txt
                    '''
                }
                
                archiveArtifacts artifacts: 'api_url.txt', onlyIfSuccessful: true
            }
        }

        
        stage('API Rest Tests') {
            agent { label 'test-agent' } 
            steps {
                
                copyArtifacts projectName: env.JOB_NAME, selector: lastSuccessful(), filter: 'api_url.txt'
                
                script {
                    def API_URL = readFile('api_url.txt').trim()
                    echo "Probando la API en: ${API_URL}"
                    
                    sh """
                        
                        curl -s -o /dev/null -w "%{http_code}" ${API_URL}/todos | grep "200"
                    """
                }
            }
        }

