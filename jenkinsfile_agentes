pipeline {
    agent none 
    
    options {
        timestamps()
        skipDefaultCheckout(true) 
    }

    environment {
        AWS_DEFAULT_REGION = "us-east-1"
        STACK_NAME = "todo-list-aws-staging"
    }

    stages {
        stage('Static Test') {
            agent { label 'static-analysis' } 
            steps {
                checkout scm 
                sh '''
                    python3 -m venv .venv
                    . .venv/bin/activate
                    pip install flake8 bandit[sarif]
                    python -m flake8 --format=pylint src > flake8.out || true
                    python -m bandit --exit-zero -r src -f sarif -o bandit.sarif
                '''
                recordIssues(tools: [flake8(pattern: 'flake8.out')])
            }
        }

        stage('Deploy') {
            agent any 
            steps {
                checkout scm
                withCredentials([...]) { 
                    sh 'sam build && sam deploy --no-confirm-changeset'
                }
            }
        }

        stage('Rest Test') {
            agent { label 'api-tests' } 
            steps {
                checkout scm 
                withCredentials([...]) {
                    sh '''
                        . .venv/bin/activate || python3 -m venv .venv && . .venv/bin/activate
                        pip install pytest requests awscli
                        
                        
                        export BASE_URL=$(aws cloudformation describe-stacks \
                            --stack-name ${STACK_NAME} \
                            --query "Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue" \
                            --output text)
                            
                        pytest test/integration/todoApiTest.py
                    '''
                }
            }
        }
        
        stage('Deploy to PROD') {
            
            agent any
            when {
                branch 'master' 
            }
            steps {
                checkout scm
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY'),
                    string(credentialsId: 'AWS_SESSION_TOKEN', variable: 'AWS_SESSION_TOKEN')
                ]) {
                    sh '''
                        set -e
                        python3 -m venv .venv
                        . .venv/bin/activate
                        pip install aws-sam-cli
                        sam build
                        # Usamos el entorno de producción aquí
                        sam deploy --config-env prod --no-confirm-changeset --stack-name todo-list-aws-prod
                    '''
                }
            }
        }

        stage('Smoke Test PROD') {
            agent { label 'api-tests' }
            when { branch 'master' }
            steps {
                checkout scm
                withCredentials([...]) {
                    sh '''
                        # Misma lógica de obtener URL pero del stack de PROD
                        BASE_URL=$(aws cloudformation describe-stacks \
                            --stack-name todo-list-aws-prod \
                            --query "Stacks[0].Outputs[?OutputKey=='BaseUrlApi'].OutputValue" \
                            --output text)
                        
                        export BASE_URL="$BASE_URL"
                        pytest test/integration/todoApiTest.py
                    '''
                }
            }
        }

    }
}